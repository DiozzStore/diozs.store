<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Don't rewrite if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Specific rule for /unsubscribe to unsubscribe.php
    RewriteRule ^unsubscribe/?$ unsubscribe.php [QSA,L]

    # Try to find .php file if no file exists
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.php [QSA,L]

    # Only redirect to index.html for non-PHP requests
    RewriteCond %{REQUEST_FILENAME} !\.php$
    RewriteCond %{REQUEST_URI} !^/[a-zA-Z0-9_.-]*\.php$
    RewriteRule ^(.*)$ index.html [QSA,L]
</IfModule>

# Cache static files
<FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "max-age=31536000, public"
</FilesMatch>

# Allow access to PHP files
<FilesMatch "\.php$">
    Allow from all
</FilesMatch>
